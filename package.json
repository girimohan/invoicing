{
  "name": "wolt-substitute-invoice",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "next build && electron-builder",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "build": {
    "appId": "com.wolt.invoice-tool",
    "productName": "Wolt Invoice Tool",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json",
      "next.config.js"
    ],
    "extraResources": [
      {
        "from": "prisma",
        "to": "prisma",
        "filter": ["schema.prisma", "*.db"]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "@react-pdf/renderer": "^3.4.4",
    "date-fns": "^3.6.0",
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.39",
    "prisma": "^5.16.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "wait-on": "^9.0.10"
  }
}
